{
  "private": true,
  "type": "module",
  "scripts": {
    "tunet:build": "node build.mjs",
    "tunet:build:watch": "node build.mjs --watch",
    "tunet:deploy:lab": "node build.mjs --deploy",
    "tunet:resources:sync": "node Dashboard/Tunet/scripts/update_tunet_v3_resources.mjs",
    "tunet:review": "node Dashboard/Tunet/scripts/tunet_playwright_review.mjs --surface all",
    "tunet:review:smoke": "node Dashboard/Tunet/scripts/tunet_playwright_review.mjs --surface rehab --smoke",
    "tunet:lab:screenshot": "node Dashboard/Tunet/scripts/tunet_playwright_review.mjs --surface rehab",
    "tinbox:check": "bash custom_components/tunet_inbox/scripts/check_tunet_inbox.sh",
    "tinbox:deploy:integration": "bash custom_components/tunet_inbox/scripts/deploy_tunet_inbox.sh",
    "tinbox:probe:runtime": "python3 custom_components/tunet_inbox/scripts/tunet_inbox_runtime_probe.py lock-conflict",
    "tinbox:test:setup": "bash custom_components/tunet_inbox/scripts/setup_tunet_inbox_test_env.sh",
    "tinbox:test": "bash custom_components/tunet_inbox/scripts/run_tunet_inbox_pytest.sh",
    "tinbox:verify": "bash custom_components/tunet_inbox/scripts/verify_tunet_inbox_release.sh",
    "tinbox:probe:api": "node custom_components/tunet_inbox/scripts/tunet_inbox_api_probe.mjs",
    "tinbox:smoke": "node custom_components/tunet_inbox/scripts/tunet_inbox_smoke.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "esbuild": "^0.25.0",
    "jsdom": "^29.0.1",
    "vitest": "^3.1.0"
  }
}
